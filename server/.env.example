# Backend base
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5174
# Inclua aqui o dominio do app e o futuro subdominio administrativo em producao.
# Ex: https://app.seudominio.com,https://admin.seudominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Firebase Admin SDK - use somente o projeto de testes no ambiente local.
FIREBASE_PROJECT_ID=sistema-nexus-dev
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Onboarding seguro
# Obrigatorio em producao. Use um valor longo e aleatorio.
ONBOARDING_CODE_SECRET=

# Em desenvolvimento, permite receber os codigos no console/resposta da API.
# Nunca habilitar em producao.
ONBOARDING_DEV_CODES=true

# Validacao de CNPJ
# brasilapi funciona para desenvolvimento. Em producao, prefira serpro quando contratado/configurado.
CNPJ_PROVIDER=brasilapi
# CNPJ_PROVIDER=serpro
# SERPRO_CNPJ_BASE_URL=
# SERPRO_CNPJ_BEARER_TOKEN=

# Envio de e-mail de verificacao
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# EMAIL_FROM=Nexar ERP <cadastro@seudominio.com>

# Envio de SMS/WhatsApp via provedor transacional
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_PHONE=
